{
  "version": "1.0",
  "install_dir": "~/.claude",
  "log_file": "install.log",
  "modules": {
    "omo": {
      "enabled": true,
      "description": "OmO multi-agent orchestration with Sisyphus coordinator",
      "dependencies": ["cr"],
      "agents": {
        "oracle": {
          "backend": "claude",
          "model": "claude-opus-4-6",
          "prompt_file": "~/.claude/skills/omo/references/oracle.md",
          "yolo": true
        },
        "librarian": {
          "backend": "claude",
          "model": "claude-sonnet-4-6",
          "prompt_file": "~/.claude/skills/omo/references/librarian.md",
          "yolo": true
        },
        "explore": {
          "backend": "claude",
          "model": "claude-sonnet-4-6",
          "prompt_file": "~/.claude/skills/omo/references/explore.md"
        },
        "develop": {
          "backend": "codex",
          "model": "gpt-5.4",
          "prompt_file": "~/.claude/skills/omo/references/develop.md",
          "reasoning": "xhigh",
          "yolo": true
        },
        "frontend-ui-ux-engineer": {
          "backend": "claude",
          "model": "claude-opus-4-6",
          "prompt_file": "~/.claude/skills/omo/references/frontend-ui-ux-engineer.md"
        },
        "document-writer": {
          "backend": "gemini",
          "model": "gemini-3-flash-preview",
          "prompt_file": "~/.claude/skills/omo/references/document-writer.md"
        },
        "code-reviewer": {
          "backend": "claude",
          "model": "claude-sonnet-4-6",
          "prompt_file": "~/.claude/skills/omo/references/code-reviewer.md"
        }
      },
      "operations": [
        {
          "type": "copy_dir",
          "source": "skills/omo",
          "target": "skills/omo",
          "description": "Install omo skill"
        }
      ]
    },
    "do": {
      "enabled": true,
      "description": "5-phase feature development workflow with codeagent orchestration",
      "dependencies": ["cr", "taste"],
      "agents": {
        "do-develop": {
          "backend": "codex",
          "model": "gpt-5.4",
          "prompt_file": "~/.claude/skills/do/agents/do-develop.md",
          "reasoning": "xhigh",
          "yolo": true
        },
        "code-explorer": {
          "backend": "claude",
          "model": "claude-sonnet-4-6",
          "prompt_file": "~/.claude/skills/do/agents/code-explorer.md"
        },
        "code-architect": {
          "backend": "claude",
          "model": "claude-opus-4-6",
          "prompt_file": "~/.claude/skills/do/agents/code-architect.md"
        },
        "do-reviewer": {
          "backend": "claude",
          "model": "claude-sonnet-4-6",
          "prompt_file": "~/.claude/skills/do/agents/do-reviewer.md"
        },
        "do-summarizer": {
          "backend": "claude",
          "model": "claude-sonnet-4-6",
          "prompt_file": "~/.claude/skills/do/agents/do-summarizer.md"
        },
        "do-frontend": {
          "backend": "claude",
          "model": "claude-opus-4-6",
          "prompt_file": "~/.claude/skills/do/agents/do-frontend.md"
        }
      },
      "operations": [
        {
          "type": "copy_dir",
          "source": "skills/do",
          "target": "skills/do",
          "description": "Install do skill with hooks"
        }
      ]
    },
    "cr": {
      "enabled": true,
      "description": "Code review checklists and reference materials for code-reviewer agent",
      "operations": [
        {
          "type": "copy_dir",
          "source": "skills/cr",
          "target": "skills/cr",
          "description": "Install cr skill"
        }
      ]
    },
    "taste": {
      "enabled": true,
      "description": "Frontend design quality rules for codeagent-wrapper skill injection",
      "operations": [
        {
          "type": "copy_dir",
          "source": "skills/taste/taste-core",
          "target": "skills/taste-core",
          "description": "Install taste-core skill"
        },
        {
          "type": "copy_dir",
          "source": "skills/taste/taste-output",
          "target": "skills/taste-output",
          "description": "Install taste-output skill"
        },
        {
          "type": "copy_dir",
          "source": "skills/taste/taste-creative",
          "target": "skills/taste-creative",
          "description": "Install taste-creative skill"
        },
        {
          "type": "copy_dir",
          "source": "skills/taste/taste-redesign",
          "target": "skills/taste-redesign",
          "description": "Install taste-redesign skill"
        }
      ]
    },
    "codeagent": {
      "enabled": true,
      "description": "codeagent skill for focused implementation with codeagent-wrapper",
      "operations": [
        {
          "type": "copy_dir",
          "source": "skills/codeagent",
          "target": "skills/codeagent",
          "description": "Install codeagent skill"
        }
      ]
    },
    "research-pro": {
      "enabled": true,
      "description": "Multi-agent academic paper reading, review, literature search, and structured output",
      "agents": {
        "content-extractor": {
          "backend": "codex",
          "model": "gpt-5.4",
          "prompt_file": "~/.claude/skills/research-pro/references/content-extractor.md",
          "reasoning": "high"
        },
        "paper-reviewer": {
          "backend": "codex",
          "model": "gpt-5.4",
          "prompt_file": "~/.claude/skills/research-pro/references/paper-reviewer.md",
          "reasoning": "xhigh"
        },
        "literature-scout": {
          "backend": "codex",
          "model": "gpt-5.4",
          "prompt_file": "~/.claude/skills/research-pro/references/literature-scout.md",
          "yolo": true,
          "reasoning": "high"
        },
        "literature-filter": {
          "backend": "codex",
          "model": "gpt-5.4",
          "prompt_file": "~/.claude/skills/research-pro/references/literature-filter.md",
          "reasoning": "high"
        },
        "paper-downloader": {
          "backend": "codex",
          "model": "gpt-5.4",
          "prompt_file": "~/.claude/skills/research-pro/references/paper-downloader.md",
          "yolo": true,
          "reasoning": "high"
        },
        "format-writer": {
          "backend": "gemini",
          "model": "gemini-3-flash-preview",
          "prompt_file": "~/.claude/skills/research-pro/references/format-writer.md"
        }
      },
      "operations": [
        {
          "type": "copy_dir",
          "source": "skills/research-pro",
          "target": "skills/research-pro",
          "description": "Install research-pro skill"
        }
      ]
    },
    "claudekit": {
      "enabled": true,
      "description": "Global hooks: dangerous command blocker and spec injection",
      "operations": [
        {
          "type": "copy_dir",
          "source": "hooks",
          "target": "hooks",
          "description": "Install global hooks (pre-bash, inject-spec)"
        }
      ]
    },
    "project-init": {
      "enabled": true,
      "description": "One-time project initialization for spec-driven development",
      "operations": [
        {
          "type": "copy_dir",
          "source": "skills/project-init",
          "target": "skills/project-init",
          "description": "Install project-init skill"
        }
      ]
    },
    "memory": {
      "enabled": true,
      "description": "Dual-layer memory system: structured experience/knowledge persistence",
      "operations": [
        {
          "type": "copy_dir",
          "source": "skills/memory/exp-search",
          "target": "skills/exp-search",
          "description": "Install exp-search skill"
        },
        {
          "type": "copy_dir",
          "source": "skills/memory/exp-reflect",
          "target": "skills/exp-reflect",
          "description": "Install exp-reflect skill"
        },
        {
          "type": "copy_dir",
          "source": "skills/memory/exp-write",
          "target": "skills/exp-write",
          "description": "Install exp-write skill"
        }
      ]
    },
    "spec": {
      "enabled": true,
      "description": "Spec-driven development lifecycle with gate-controlled phases",
      "dependencies": ["memory"],
      "agents": {
        "spec-explorer": {
          "backend": "claude",
          "model": "claude-sonnet-4-6",
          "prompt_file": "~/.claude/skills/spec/references/spec-explorer.md"
        },
        "spec-planner": {
          "backend": "claude",
          "model": "claude-opus-4-6",
          "prompt_file": "~/.claude/skills/spec/references/spec-planner.md"
        },
        "plan-reviewer": {
          "backend": "codex",
          "model": "gpt-5.4",
          "prompt_file": "~/.claude/skills/spec/references/plan-reviewer.md",
          "reasoning": "xhigh"
        },
        "spec-tester": {
          "backend": "claude",
          "model": "claude-sonnet-4-6",
          "prompt_file": "~/.claude/skills/spec/references/spec-tester.md",
          "yolo": true
        }
      },
      "operations": [
        {
          "type": "copy_dir",
          "source": "skills/spec",
          "target": "skills/spec",
          "description": "Install spec skill with sub-skills"
        }
      ]
    }
  }
}
